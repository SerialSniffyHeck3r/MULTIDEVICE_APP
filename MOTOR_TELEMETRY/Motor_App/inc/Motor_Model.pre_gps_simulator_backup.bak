/* -------------------------------------------------------------------------- */
/*  OBD link 상태                                                              */
/* -------------------------------------------------------------------------- */
typedef enum
{
    MOTOR_OBD_LINK_DISCONNECTED = 0u,
    MOTOR_OBD_LINK_SEARCHING,
    MOTOR_OBD_LINK_CONNECTING,
    MOTOR_OBD_LINK_CONNECTED,
    MOTOR_OBD_LINK_ERROR,
    MOTOR_OBD_LINK_COUNT
} motor_obd_link_state_t;

/* -------------------------------------------------------------------------- */
/*  로그 recorder 상태                                                         */
/* -------------------------------------------------------------------------- */
typedef enum
{
    MOTOR_RECORD_STATE_IDLE = 0u,
    MOTOR_RECORD_STATE_ARMED,
    MOTOR_RECORD_STATE_RECORDING,
    MOTOR_RECORD_STATE_PAUSED,
    MOTOR_RECORD_STATE_CLOSING,
    MOTOR_RECORD_STATE_ERROR,
    MOTOR_RECORD_STATE_COUNT
} motor_record_state_t;

/* -------------------------------------------------------------------------- */
/*  데이터 필드 catalog                                                        */
/*                                                                            */
/*  Data Field page 1/2 는 이 catalog 중에서 15개씩 고른다.                   */
/* -------------------------------------------------------------------------- */
typedef enum
{
    MOTOR_FIELD_NONE = 0u,
    MOTOR_FIELD_SPEED,
    MOTOR_FIELD_SPEED_SOURCE,
    MOTOR_FIELD_BANK,
    MOTOR_FIELD_BANK_MAX_LEFT,
    MOTOR_FIELD_BANK_MAX_RIGHT,
    MOTOR_FIELD_G_LAT,
    MOTOR_FIELD_G_LAT_MAX_LEFT,
    MOTOR_FIELD_G_LAT_MAX_RIGHT,
    MOTOR_FIELD_G_LON,
    MOTOR_FIELD_G_ACCEL_MAX,
    MOTOR_FIELD_G_BRAKE_MAX,
    MOTOR_FIELD_ALTITUDE,
    MOTOR_FIELD_REL_ALTITUDE,
    MOTOR_FIELD_GRADE_PERCENT,
    MOTOR_FIELD_HEADING,
    MOTOR_FIELD_GPS_FIX,
    MOTOR_FIELD_GPS_SATS,
    MOTOR_FIELD_GPS_HACC,
    MOTOR_FIELD_GPS_VACC,
    MOTOR_FIELD_LATITUDE,
    MOTOR_FIELD_LONGITUDE,
    MOTOR_FIELD_TIME,
    MOTOR_FIELD_RIDE_TIME,
    MOTOR_FIELD_MOVING_TIME,
    MOTOR_FIELD_DISTANCE,
    MOTOR_FIELD_TRIP_A,
    MOTOR_FIELD_TRIP_B,
    MOTOR_FIELD_COOLANT_TEMP,
    MOTOR_FIELD_RPM,
    MOTOR_FIELD_GEAR,
    MOTOR_FIELD_BATTERY,
    MOTOR_FIELD_OBD_LINK,
    MOTOR_FIELD_MAINT_DUE_COUNT,
    MOTOR_FIELD_NEXT_SERVICE,
    MOTOR_FIELD_RECORD_STATE,
    MOTOR_FIELD_SD_STATE,
    MOTOR_FIELD_BT_STATE,
    MOTOR_FIELD_ENGINE_HOURS,
    MOTOR_FIELD_OUTSIDE_TEMP,
    MOTOR_FIELD_COUNT
} motor_data_field_id_t;

/* -------------------------------------------------------------------------- */
/*  단위 설정                                                                  */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t preset;              /* motor_unit_preset_t raw                      */
    uint8_t speed;               /* motor_speed_unit_t raw                       */
    uint8_t distance;            /* motor_distance_unit_t raw                    */
    uint8_t altitude;            /* motor_altitude_unit_t raw                    */
    uint8_t temperature;         /* motor_temp_unit_t raw                        */
    uint8_t pressure;            /* motor_pressure_unit_t raw                    */
    uint8_t economy;             /* motor_economy_unit_t raw                     */
    uint8_t reserved0;
} motor_unit_settings_t;

/* -------------------------------------------------------------------------- */
/*  Display 설정 묶음                                                          */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t brightness_mode;                       /* motor_display_brightness_mode_t raw */
    uint8_t manual_brightness_percent;            /* 0..100                               */
    int8_t  auto_continuous_bias_steps;           /* -2..+2                               */
    uint8_t auto_day_night_night_threshold_percent;
    uint8_t auto_day_night_super_night_threshold_percent;
    uint8_t auto_day_night_night_brightness_percent;
    uint8_t auto_day_night_super_night_brightness_percent;
    uint8_t contrast_raw;                         /* UC1608 contrast raw                  */
    uint8_t temperature_compensation_raw;         /* UC1608 temp compensation raw         */
    uint8_t smart_update_enabled;                 /* smart update cache enable            */
    uint8_t frame_limit_enabled;                  /* frame limiter enable                 */
    uint8_t page_wrap_enabled;                    /* page wrap for drive screens          */
    uint8_t lock_while_moving;                    /* moving state lock for settings       */
    uint8_t main_top_mode;                        /* motor_main_top_mode_t raw            */
    uint8_t main_speed_scale;                     /* motor_main_speed_scale_t raw         */
    uint8_t main_rpm_scale;                       /* motor_main_rpm_scale_t raw           */
    uint8_t main_g_scale;                         /* motor_main_g_scale_t raw             */
} motor_display_settings_t;

/* -------------------------------------------------------------------------- */
/*  GPS 설정 묶음                                                              */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t  receiver_profile;                  /* app_gps_boot_profile_t raw            */
    uint8_t  power_profile;                     /* app_gps_power_profile_t raw           */
    uint8_t  dynamic_model;                     /* motor_gps_dynamic_model_t raw         */
    uint8_t  static_hold_enabled;
    uint8_t  low_speed_course_filter_enabled;
    uint8_t  low_speed_velocity_filter_enabled;
    uint8_t  rtc_gps_sync_enabled;
    uint8_t  rtc_gps_sync_interval_min;
    uint16_t course_valid_min_speed_kmh_x10;
    uint16_t breadcrumb_min_distance_m;
} motor_gps_settings_t;

/* -------------------------------------------------------------------------- */
/*  주행 로그 / 세션 설정                                                      */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t  auto_start_enabled;
    uint8_t  auto_pause_enabled;
    uint8_t  summary_popup_enabled;
    uint8_t  raw_imu_log_enabled;
    uint16_t auto_start_speed_kmh_x10;
    uint16_t auto_stop_idle_seconds;
} motor_recording_settings_t;

/* -------------------------------------------------------------------------- */
/*  다이내믹스 설정                                                            */
/* -------------------------------------------------------------------------- */
typedef struct
{
    /* ---------------------------------------------------------------------- */
    /*  서비스 활성 / 외부 aid 정책                                            */
    /* ---------------------------------------------------------------------- */
    uint8_t  enabled;
    uint8_t  auto_zero_on_boot;
    uint8_t  gnss_aid_enabled;
    uint8_t  obd_aid_enabled;

    /* ---------------------------------------------------------------------- */
    /*  장착 축 / yaw trim                                                      */
    /* ---------------------------------------------------------------------- */
    uint8_t  mount_forward_axis;                /* app_bike_axis_t raw                   */
    uint8_t  mount_left_axis;                   /* app_bike_axis_t raw                   */
    int16_t  mount_yaw_trim_deg_x10;

    /* ---------------------------------------------------------------------- */
    /*  shared BIKE_DYNAMICS tuning mirror                                     */
    /*                                                                          */
    /*  중요한 ownership 규칙                                                   */
    /*  - canonical low-level owner는 APP_STATE.settings.bike 이다.            */
    /*  - Motor_App는 rider-facing settings 저장소를 별도로 유지하되,          */
    /*    Commit 시 아래 항목들을 shared setting으로 그대로 미러링한다.        */
    /*  - 따라서 high-level UI는 Motor settings만 수정하고, 실제 estimator는   */
    /*    shared BIKE_DYNAMICS service가 그 값을 사용한다.                     */
    /* ---------------------------------------------------------------------- */
    uint16_t imu_accel_lsb_per_g;
    uint16_t imu_gyro_lsb_per_dps_x10;
    uint16_t imu_gravity_tau_ms;
    uint16_t imu_linear_tau_ms;
    uint16_t imu_attitude_accel_gate_mg;
    uint16_t imu_jerk_gate_mg_per_s;
    uint16_t imu_predict_min_trust_permille;
    uint16_t imu_stale_timeout_ms;

    uint16_t output_deadband_mg;
    uint16_t output_clip_mg;
    uint16_t lean_display_tau_ms;
    uint16_t grade_display_tau_ms;
    uint16_t accel_display_tau_ms;

    uint16_t gnss_min_speed_kmh_x10;
    uint16_t gnss_max_speed_acc_kmh_x10;
    uint16_t gnss_max_head_acc_deg_x10;
    uint16_t gnss_bias_tau_ms;
    uint16_t gnss_outlier_gate_mg;
    uint16_t obd_stale_timeout_ms;
} motor_dynamics_settings_t;

/* -------------------------------------------------------------------------- */
/*  정비 항목 설정                                                             */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t  enabled;
    char     label[16];
    uint32_t interval_km_x1000;
    uint16_t interval_days;
    uint32_t interval_engine_seconds;
    uint32_t last_service_odo_m;
    uint32_t last_service_engine_seconds;
    uint16_t last_service_year;
    uint8_t  last_service_month;
    uint8_t  last_service_day;
} motor_service_item_config_t;

typedef struct
{
    uint32_t due_soon_distance_m;
    uint16_t due_soon_days;
    motor_service_item_config_t items[MOTOR_SERVICE_ITEM_COUNT];
} motor_maintenance_settings_t;

/* -------------------------------------------------------------------------- */
/*  OBD 설정                                                                   */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t  autoconnect_enabled;
    uint8_t  preferred_speed_source;           /* app_bike_speed_source_t raw 의미 차용 */
    uint16_t coolant_warn_temp_c_x10;
    uint16_t shift_light_rpm;
} motor_obd_settings_t;

/* -------------------------------------------------------------------------- */
/*  시스템 / UI 설정                                                           */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t menu_wrap_enabled;
    uint8_t show_debug_stubs;
    uint8_t ride_summary_popup_enabled;
    uint8_t reserved0;
} motor_system_settings_t;

/* -------------------------------------------------------------------------- */
/*  Motor_App 전체 설정                                                        */
/* -------------------------------------------------------------------------- */
typedef struct
{
    motor_unit_settings_t         units;
    motor_display_settings_t      display;
    motor_gps_settings_t          gps;
    motor_recording_settings_t    recording;
    motor_dynamics_settings_t     dynamics;
    motor_maintenance_settings_t  maintenance;
    motor_obd_settings_t          obd;
    motor_system_settings_t       system;
    uint8_t                       data_fields[MOTOR_DATA_FIELD_PAGE_COUNT][MOTOR_DATA_FIELD_SLOT_COUNT];
} motor_settings_t;

/* -------------------------------------------------------------------------- */
/*  내비/항법 런타임                                                            */
/* -------------------------------------------------------------------------- */
typedef struct
{
    bool     valid;
    bool     moving;
    bool     fix_ok;
    bool     heading_valid;
    uint8_t  fix_type;
    uint8_t  sats_used;
    int32_t  lat_e7;
    int32_t  lon_e7;
    int32_t  speed_mmps;
    uint16_t speed_kmh_x10;
    int32_t  heading_deg_x10;
    int32_t  altitude_cm;
    int32_t  rel_altitude_cm;
    uint32_t hacc_mm;
    uint32_t vacc_mm;
    uint32_t last_fix_ms;
} motor_nav_state_t;

/* -------------------------------------------------------------------------- */
/*  Breadcrumb / history                                                       */
/* -------------------------------------------------------------------------- */
typedef struct
{
    int32_t lat_e7;
    int32_t lon_e7;
    int32_t alt_cm;
    uint32_t tick_ms;
    uint8_t valid;
} motor_breadcrumb_point_t;

typedef struct
{
    motor_breadcrumb_point_t points[MOTOR_BREADCRUMB_POINT_COUNT];
    uint16_t head;
    uint16_t count;
    int32_t  home_lat_e7;
    int32_t  home_lon_e7;
    uint8_t  home_valid;
} motor_breadcrumb_state_t;

/* -------------------------------------------------------------------------- */
/*  주행 dynamics 런타임                                                       */
/* -------------------------------------------------------------------------- */
typedef struct
{
    /* ---------------------------------------------------------------------- */
    /*  low-level canonical flags / routing                                     */
    /*                                                                          */
    /*  이 구조체는 intentionally two-layer shape를 가진다.                    */
    /*                                                                          */
    /*  1) est_*                                                               */
    /*     - shared BIKE_DYNAMICS가 publish 한 canonical 추정 결과             */
    /*     - logger / peak detector / future post-ride analysis 가 사용        */
    /*                                                                          */
    /*  2) display-facing alias fields                                          */
    /*     - 현재 UI가 바로 쓰는 bank_deg_x10 / lat_accel_mg 등                */
    /*     - 현 시점에서는 est_*를 그대로 mirror 하되,                         */
    /*       이후 UI-only smoothing을 넣더라도 logger는 영향을 받지 않게       */
    /*       구조를 미리 분리해 둔다.                                           */
    /* ---------------------------------------------------------------------- */
    bool     initialized;
    bool     zero_valid;
    bool     imu_valid;
    bool     gnss_aid_valid;
    bool     gnss_heading_valid;
    bool     obd_speed_valid;
    uint16_t confidence_permille;
    uint8_t  speed_source;                         /* app_bike_speed_source_t raw        */
    uint8_t  estimator_mode;                      /* app_bike_estimator_mode_t raw      */
    uint8_t  heading_source;                      /* app_bike_heading_source_t raw      */
    uint8_t  reserved0;
    uint32_t last_source_update_ms;
    uint32_t last_zero_capture_ms;

    /* ---------------------------------------------------------------------- */
    /*  canonical estimator outputs                                             */
    /* ---------------------------------------------------------------------- */
    int16_t  est_bank_deg_x10;
    int16_t  est_grade_deg_x10;
    int16_t  est_bank_rate_dps_x10;
    int16_t  est_grade_rate_dps_x10;
    int16_t  est_heading_deg_x10;
    int16_t  est_yaw_rate_dps_x10;

    int32_t  est_lat_accel_mg;
    int32_t  est_lon_accel_mg;
    int32_t  est_lat_accel_imu_mg;
    int32_t  est_lon_accel_imu_mg;
    int32_t  lat_bias_mg;
    int32_t  lon_bias_mg;

    /* ---------------------------------------------------------------------- */
    /*  display-facing mirror                                                   */
    /* ---------------------------------------------------------------------- */
    int16_t  bank_deg_x10;
    int16_t  grade_deg_x10;
    int16_t  bank_rate_dps_x10;
    int16_t  grade_rate_dps_x10;
    int16_t  heading_deg_x10;
    int16_t  yaw_rate_dps_x10;

    int32_t  lat_accel_mg;
    int32_t  lon_accel_mg;
    int32_t  lat_accel_imu_mg;
    int32_t  lon_accel_imu_mg;

    /* ---------------------------------------------------------------------- */
    /*  session peaks / history                                                 */
    /* ---------------------------------------------------------------------- */
    int16_t  max_left_bank_deg_x10;
    int16_t  max_right_bank_deg_x10;
    int32_t  max_left_lat_mg;
    int32_t  max_right_lat_mg;
    int32_t  max_accel_mg;
    int32_t  max_brake_mg;

    int16_t  bank_history_x10[MOTOR_HISTORY_SAMPLE_COUNT];
    int16_t  lat_history_x10[MOTOR_HISTORY_SAMPLE_COUNT];
    int16_t  alt_history_m[MOTOR_HISTORY_SAMPLE_COUNT];
    int16_t  grade_history_x10[MOTOR_HISTORY_SAMPLE_COUNT];
    uint16_t history_head;
} motor_dynamics_state_t;

/* -------------------------------------------------------------------------- */
/*  OBD / vehicle runtime                                                      */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t  link_state;                             /* motor_obd_link_state_t raw         */
    bool     connected;
    bool     data_valid;
    bool     dtc_present;
    bool     rpm_valid;
    bool     coolant_valid;
    bool     gear_valid;
    bool     battery_valid;
    uint32_t last_update_ms;
    uint16_t rpm;
    int16_t  coolant_temp_c_x10;
    int8_t   gear;
    uint8_t  throttle_percent;
    uint16_t battery_mv;
    uint8_t  dtc_count;
} motor_vehicle_state_t;

typedef struct
{
    uint32_t distance_m;
    uint32_t moving_seconds;
    uint32_t ride_seconds;
    uint16_t max_speed_kmh_x10;
    uint16_t reserved0;
} motor_trip_metrics_t;

/* -------------------------------------------------------------------------- */
/*  세션 / 누적 통계                                                           */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint32_t session_id;
    bool     active;
    uint32_t start_ms;
    uint32_t stop_ms;
    uint32_t moving_seconds;
    uint32_t stopped_seconds;
    uint32_t ride_seconds;
    uint32_t distance_m;
    uint32_t trip_a_m;
    uint32_t trip_b_m;
    uint16_t max_speed_kmh_x10;
    uint16_t marker_count;
    motor_trip_metrics_t trip_a_stats;
    motor_trip_metrics_t trip_b_stats;
    motor_trip_metrics_t trip_refuel;
    motor_trip_metrics_t trip_today;
    motor_trip_metrics_t trip_ignition;
    uint16_t today_anchor_year;
    uint8_t  today_anchor_month;
    uint8_t  today_anchor_day;
    uint8_t  today_reset_pending;
    uint8_t  reserved1[3];
} motor_session_state_t;

/* -------------------------------------------------------------------------- */
/*  Recorder 런타임                                                            */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t  state;                                   /* motor_record_state_t raw           */
    bool     open_ok;
    bool     graceful_close_done;
    bool     start_requested;
    bool     stop_requested;
    bool     marker_requested;
    uint32_t last_open_ms;
    uint32_t last_write_ms;
    uint32_t last_flush_ms;
    uint32_t bytes_written;
    uint32_t drop_count;
    uint32_t record_sequence;
    char     file_name[MOTOR_RECORD_FILENAME_MAX];
} motor_record_runtime_t;

/* -------------------------------------------------------------------------- */
/*  Maintenance 런타임                                                         */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint32_t odo_total_m;
    uint32_t engine_on_seconds_total;
    uint8_t  due_count;
    uint8_t  next_due_index;
    uint8_t  due_flags[MOTOR_SERVICE_ITEM_COUNT];
} motor_maintenance_state_t;

/* -------------------------------------------------------------------------- */
/*  UI runtime                                                                 */
/* -------------------------------------------------------------------------- */
typedef struct
{
    uint8_t  screen;                                  /* motor_screen_t raw                 */
    uint8_t  previous_drive_screen;                   /* motor_screen_t raw                 */
    uint8_t  selected_index;                          /* menu/settings selected row         */
    uint8_t  selected_slot;                           /* data field selected slot           */
    uint8_t  first_visible_row;                       /* scrolling list first row           */
    uint8_t  editing;                                 /* value edit latch                   */
    uint8_t  screen_locked;                           /* moving lock or manual lock         */
    uint8_t  redraw_requested;                        /* next frame force redraw            */
    uint8_t  overlay_visible;                         /* drive bottom bar overlay visible   */
    uint8_t  overlay_key_armed;                       /* first short press only opens bar   */
    uint8_t  bottom_page;                             /* main bottom strip page             */
    uint8_t  reserved0;
    uint32_t overlay_until_ms;                        /* overlay bottom bar timeout         */
    uint32_t toast_until_ms;
    char     toast_text[MOTOR_UI_TOAST_TEXT_MAX];
} motor_ui_state_t;

/* -------------------------------------------------------------------------- */
/*  Motor_App 전체 런타임 state                                                */
/* -------------------------------------------------------------------------- */
typedef struct
{
    app_state_t               snapshot;              /* 공용 APP_STATE 전체 snapshot       */
    motor_settings_t          settings;              /* 앱 전용 고수준 정책 snapshot       */
    motor_nav_state_t         nav;
    motor_breadcrumb_state_t  breadcrumb;
    motor_dynamics_state_t    dyn;
    motor_vehicle_state_t     vehicle;
    motor_session_state_t     session;
    motor_record_runtime_t    record;
    motor_maintenance_state_t maintenance;
    motor_ui_state_t          ui;
    uint32_t                  now_ms;
    uint32_t                  last_task_ms;
} motor_state_t;

#ifdef __cplusplus
}
#endif

#endif /* MOTOR_MODEL_H */

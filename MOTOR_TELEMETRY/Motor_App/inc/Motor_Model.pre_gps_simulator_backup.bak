
#ifndef MOTOR_MODEL_H
#define MOTOR_MODEL_H

#include "APP_STATE.h"

#include <stdbool.h>
#include <stdint.h>

#ifdef __cplusplus
extern "C" {
#endif

/* -------------------------------------------------------------------------- */
/*  Motor_App 공용 모델 정의                                                  */
/*                                                                            */
/*  이 헤더는 Motor_App 상위 계층 전체가 공유하는 타입만 모아 둔 곳이다.       */
/*                                                                            */
/*  중요한 계층 규칙                                                           */
/*  - 저수준 센서 드라이버가 직접 제공하는 raw 값은 APP_STATE snapshot 안에만   */
/*    존재한다.                                                                */
/*  - Motor_App 안의 각 모듈은 raw를 다시 전역으로 흩뿌리지 않고,               */
/*    "라이더가 의미 있게 쓸 수 있는 값" 으로 가공한 뒤 이 모델 구조체 안에     */
/*    정리한다.                                                                */
/*  - 따라서 UI / logger / maintenance / OBD stub 모두                        */
/*    motor_state_t 만 보면 된다.                                              */
/* -------------------------------------------------------------------------- */

#ifndef MOTOR_DATA_FIELD_SLOT_COUNT
#define MOTOR_DATA_FIELD_SLOT_COUNT         15u
#endif

#ifndef MOTOR_DATA_FIELD_PAGE_COUNT
#define MOTOR_DATA_FIELD_PAGE_COUNT         2u
#endif

#ifndef MOTOR_HISTORY_SAMPLE_COUNT
#define MOTOR_HISTORY_SAMPLE_COUNT          64u
#endif

#ifndef MOTOR_BREADCRUMB_POINT_COUNT
#define MOTOR_BREADCRUMB_POINT_COUNT        96u
#endif

#ifndef MOTOR_SERVICE_ITEM_COUNT
#define MOTOR_SERVICE_ITEM_COUNT            6u
#endif

#ifndef MOTOR_UI_TOAST_TEXT_MAX
#define MOTOR_UI_TOAST_TEXT_MAX             48u
#endif

#ifndef MOTOR_RECORD_FILENAME_MAX
#define MOTOR_RECORD_FILENAME_MAX           40u
#endif

#ifndef MOTOR_MENU_ITEM_MAX
#define MOTOR_MENU_ITEM_MAX                 8u
#endif

/* -------------------------------------------------------------------------- */
/*  화면 식별자                                                                */
/*                                                                            */
/*  drive screen 은 라이딩 중 반복해서 넘겨 보는 핵심 페이지들이고,             */
/*  menu / settings / stub screen 은 정차 또는 설정 시 진입하는 페이지다.       */
/* -------------------------------------------------------------------------- */
typedef enum
{
    MOTOR_SCREEN_MAIN = 0u,
    MOTOR_SCREEN_DATA_FIELD_1,
    MOTOR_SCREEN_DATA_FIELD_2,
    MOTOR_SCREEN_CORNER,
    MOTOR_SCREEN_COMPASS,
    MOTOR_SCREEN_BREADCRUMB,
    MOTOR_SCREEN_ALTITUDE,
    MOTOR_SCREEN_HORIZON,
    MOTOR_SCREEN_VEHICLE_SUMMARY,

    MOTOR_SCREEN_MENU,
    MOTOR_SCREEN_ACCEL_TEST_STUB,
    MOTOR_SCREEN_LAP_TIMER_STUB,
    MOTOR_SCREEN_LOG_VIEW_STUB,
    MOTOR_SCREEN_OBD_CONNECT_STUB,
    MOTOR_SCREEN_OBD_DTC_STUB,

    MOTOR_SCREEN_SETTINGS_ROOT,
    MOTOR_SCREEN_SETTINGS_DISPLAY,
    MOTOR_SCREEN_SETTINGS_GPS,
    MOTOR_SCREEN_SETTINGS_UNITS,
    MOTOR_SCREEN_SETTINGS_RECORDING,
    MOTOR_SCREEN_SETTINGS_DYNAMICS,
    MOTOR_SCREEN_SETTINGS_MAINTENANCE,
    MOTOR_SCREEN_SETTINGS_OBD,
    MOTOR_SCREEN_SETTINGS_SYSTEM,

    MOTOR_SCREEN_COUNT
} motor_screen_t;

/* -------------------------------------------------------------------------- */
/*  메인 메뉴 항목                                                             */
/* -------------------------------------------------------------------------- */
typedef enum
{
    MOTOR_MENU_ITEM_ACCEL_TEST = 0u,
    MOTOR_MENU_ITEM_LAP_TIMER,
    MOTOR_MENU_ITEM_RIDE_LOGS,
    MOTOR_MENU_ITEM_OBD_CONNECT,
    MOTOR_MENU_ITEM_OBD_DTC,
    MOTOR_MENU_ITEM_SETTINGS,
    MOTOR_MENU_ITEM_COUNT
} motor_menu_item_t;

/* -------------------------------------------------------------------------- */
/*  단위 프리셋                                                                */
/*                                                                            */
/*  사용자가 Overall Unit 에서 Metric / English / Imperial 을 선택하면         */
/*  하위 개별 단위들이 한 번에 preset 된다.                                     */
/*  그 뒤 하위 항목을 따로 조절하면 내부적으로 CUSTOM으로 바뀐다.             */
/* -------------------------------------------------------------------------- */
typedef enum
{
    MOTOR_UNIT_PRESET_METRIC = 0u,
    MOTOR_UNIT_PRESET_ENGLISH,
    MOTOR_UNIT_PRESET_IMPERIAL,
    MOTOR_UNIT_PRESET_CUSTOM,
    MOTOR_UNIT_PRESET_COUNT
} motor_unit_preset_t;

typedef enum
{
    MOTOR_SPEED_UNIT_KMH = 0u,
    MOTOR_SPEED_UNIT_MPH,
    MOTOR_SPEED_UNIT_COUNT
} motor_speed_unit_t;

typedef enum
{
    MOTOR_DISTANCE_UNIT_KM = 0u,
    MOTOR_DISTANCE_UNIT_MI,
    MOTOR_DISTANCE_UNIT_COUNT
} motor_distance_unit_t;

typedef enum
{
    MOTOR_ALTITUDE_UNIT_M = 0u,
    MOTOR_ALTITUDE_UNIT_FT,
    MOTOR_ALTITUDE_UNIT_COUNT
} motor_altitude_unit_t;

typedef enum
{
    MOTOR_TEMP_UNIT_C = 0u,
    MOTOR_TEMP_UNIT_F,
    MOTOR_TEMP_UNIT_COUNT
} motor_temp_unit_t;

typedef enum
{
    MOTOR_PRESSURE_UNIT_HPA = 0u,
    MOTOR_PRESSURE_UNIT_PSI,
    MOTOR_PRESSURE_UNIT_COUNT
} motor_pressure_unit_t;

typedef enum
{
    MOTOR_ECON_UNIT_L_PER_100KM = 0u,
    MOTOR_ECON_UNIT_MPG_US,
    MOTOR_ECON_UNIT_MPG_UK,
    MOTOR_ECON_UNIT_COUNT
} motor_economy_unit_t;

/* -------------------------------------------------------------------------- */
/*  Display 설정                                                               */
/* -------------------------------------------------------------------------- */
typedef enum
{
    MOTOR_DISPLAY_BRIGHTNESS_AUTO_CONTINUOUS = 0u,
    MOTOR_DISPLAY_BRIGHTNESS_AUTO_DAY_NITE,
    MOTOR_DISPLAY_BRIGHTNESS_MANUAL_PERCENT,
    MOTOR_DISPLAY_BRIGHTNESS_COUNT
